# ================================================================
# Document AI Assistant — Frontend Environment Variables
#
# SETUP:
#   cp .env.example .env.local     (for local dev)
#   cp .env.example .env.production (for production builds)
#
# On Vercel: add these in Project → Settings → Environment Variables
# ================================================================

# Backend API URL
# Local dev: leave empty — package.json proxy handles it
# Production: set to your Render backend URL (no trailing slash)
REACT_APP_API_URL=https://document-ai-backend.onrender.com
