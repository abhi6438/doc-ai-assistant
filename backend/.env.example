# ================================================================
# Document AI Assistant — Backend Environment Variables
#
# SETUP:
#   cp .env.example .env
#   Then fill in the values below.
#   The app loads .env automatically on startup.
# ================================================================


# ── LLM Backend selection ────────────────────────────────────────
# Options: groq | openai | local
# Default: groq  (free, no credit card required)
LLM_BACKEND=groq


# ── GROQ (FREE — recommended for demos) ─────────────────────────
# 1. Go to  https://console.groq.com
# 2. Sign up (GitHub / Google login, no credit card needed)
# 3. Go to API Keys → Create API Key
# 4. Paste it below
GROQ_API_KEY=gsk_your_groq_key_here

# Free Groq models to choose from:
#   llama-3.1-8b-instant      ← fastest (default)
#   llama-3.3-70b-versatile   ← smartest
#   mixtral-8x7b-32768        ← long documents
#   gemma2-9b-it              ← Google model
GROQ_MODEL=llama-3.1-8b-instant


# ── OPENAI (PAID — optional) ─────────────────────────────────────
# Only needed if LLM_BACKEND=openai
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o-mini


# ── OLLAMA (LOCAL — optional) ─────────────────────────────────────
# Only needed if LLM_BACKEND=local
# Requires Ollama running: https://ollama.com/download
# OLLAMA_MODEL=llama3
# OLLAMA_BASE_URL=http://localhost:11434


# ── RAG settings ─────────────────────────────────────────────────
# Number of document chunks to include in each answer's context
TOP_K_RESULTS=5
